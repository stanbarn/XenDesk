# Copy to `.env` and fill in real values. Never commit `.env`.

# PostgreSQL connection string.
# The default below matches the Docker quickstart in the README, so a fresh
# `cp .env.example .env` works out of the box for local dev.
# Production: replace it with your Neon pooled connection string.
DATABASE_URL="postgresql://xendesk:xendesk_dev_pw@localhost:5433/xendesk?schema=public"

# Auth.js secret — generate with: npx auth secret
AUTH_SECRET="generate-a-strong-secret"

# Base URL of the deployed app (e.g. https://xendesk.vercel.app). Optional locally.
AUTH_URL="http://localhost:3000"

# Set to "true" to enable the destructive agent-only reseed endpoint
# (POST /api/admin/seed), e.g. on the demo deployment. Leave unset otherwise.
ENABLE_SEED_ENDPOINT="false"

# Tests use DATABASE_URL with "_test" appended unless TEST_DATABASE_URL is set.
# When DATABASE_URL points at a remote DB (e.g. Neon), set this to a LOCAL test
# database (a gitignored .env.test is a good place) so tests never touch it.
# TEST_DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/xendesk_test?schema=public"
