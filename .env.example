# Copy to `.env` and fill in real values. Never commit `.env`.

# PostgreSQL connection string.
# Local dev (Docker, see README): postgresql://xendesk:xendesk_dev_pw@localhost:5433/xendesk?schema=public
# Production: your Neon pooled connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Auth.js secret — generate with: npx auth secret
AUTH_SECRET="generate-a-strong-secret"

# Base URL of the deployed app (e.g. https://xendesk.vercel.app). Optional locally.
AUTH_URL="http://localhost:3000"
